    "firebase-admin": "^13.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "typescript-eslint": "^8"
